<?xml version="1.0" encoding="utf-8"?>
<!--
    This XML file defines a menu with one item for adding a clothing item.
    It includes:
    - A menu item with an icon representing an "add" action.
    - The title for the item is sourced from a string resource (`menu_addClothingItem`).
    - The item is displayed in the action bar or toolbar at all times (using `showAsAction="always"`).
-->

<menu xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <item
        android:id="@+id/item_add"
        android:icon="@android:drawable/ic_menu_add"
        android:title="@string/menu_addClothingItem"
        app:showAsAction="always" />

</menu>
